# ============================================================
# 육효의 세계 — Streamlit Cloud Secrets 설정 예시
# ============================================================
# 이 파일은 예시입니다. 실제 값으로 채운 뒤
# Streamlit Cloud 대시보드 > App settings > Secrets 에 붙여넣으세요.
# 이 파일 자체는 GitHub에 커밋해도 안전합니다 (실제 키가 없으므로).
# ============================================================

# ── Google OAuth (st.login) ─────────────────────────────────
[auth]
redirect_uri   = "https://6hyo6hyo.streamlit.app/oauth2callback"
cookie_secret  = "최소-32자-랜덤-문자열-여기에-입력하세요"

[auth.google]
client_id     = "123456789-xxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxx"

# ── Supabase ────────────────────────────────────────────────
[supabase]
url = "https://xxxxxxxxxxxxxxxx.supabase.co"
key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx"   # service_role key

# ── 앱 설정 ────────────────────────────────────────────────
GEMINI_API_KEY = "AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
OWNER_EMAIL    = "your-email@gmail.com"
